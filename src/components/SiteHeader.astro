---
const links = [
  { href: "#building", label: "Building" },
  { href: "#work", label: "Work" },
  { href: "#offclock", label: "Off the clock" },
  { href: "#contact", label: "Contact" },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-20 border-b border-transparent transition-[background,border-color,backdrop-filter] duration-200">
  <div class="site-container flex min-h-[72px] items-center justify-between gap-6">
    <a class="font-mono text-[0.84rem] tracking-[0.04em]" href="/" aria-label="Luke Rucker home">luke<span class="text-[var(--accent)]">*</span>rucker</a>
    <nav class="flex gap-[30px] max-md:hidden" aria-label="Primary navigation">
      {links.map((link) => <a class="font-mono text-xs tracking-[0.05em] text-[var(--ink-2)] transition-colors hover:text-[var(--ink)]" href={link.href}>{link.label}</a>)}
    </nav>
    <div class="font-mono text-xs tracking-[0.05em] text-[var(--ink-3)]" id="clock" aria-label="Current Central Time">--:-- CT</div>
  </div>
</header>

<script is:inline>
  const header = document.getElementById("site-header");
  const clock = document.getElementById("clock");

  function updateHeader() {
    header?.classList.toggle("is-scrolled", window.scrollY > 40);
  }

  function updateClock() {
    if (!clock) return;

    try {
      const time = new Date().toLocaleTimeString("en-US", {
        timeZone: "America/Chicago",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      });
      clock.textContent = `${time} CT`;
    } catch {
      clock.textContent = "CT";
    }
  }

  updateHeader();
  updateClock();
  window.addEventListener("scroll", updateHeader, { passive: true });
  window.setInterval(updateClock, 20000);
</script>
