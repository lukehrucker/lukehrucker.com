---
interface Props {
  number: string;
  title: string;
  subtitle: string;
}

const { number, title, subtitle } = Astro.props;
---

<div class="mb-14 flex items-baseline gap-5 max-sm:block">
  <span class="font-mono text-[0.81rem] text-[var(--accent)] max-sm:mb-3.5 max-sm:block">{number}</span>
  <div>
    <h2 class="m-0 text-[clamp(1.75rem,4vw,2.9rem)] font-semibold leading-none tracking-[-0.03em]">{title}</h2>
    <p class="mt-3 max-w-[56ch] text-base leading-[1.6] text-[var(--ink-2)]">{subtitle}</p>
  </div>
</div>
