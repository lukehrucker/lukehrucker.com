<section class="relative flex min-h-svh items-center overflow-hidden">
  <div class="pointer-events-none absolute -left-[8%] -top-[34%] z-0 size-[68rem] rounded-full bg-[radial-gradient(circle,var(--accent-soft),transparent_62%)] blur-[8px]"></div>
  <div class="pointer-events-none absolute -bottom-[28%] -right-[10%] z-0 size-[44rem] rounded-full bg-[radial-gradient(circle,rgb(241_87_42_/_10%),transparent_64%)]"></div>
  <div class="relative z-[1] mx-auto grid w-[min(100%-44px,1180px)] grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] items-center gap-[clamp(2rem,6vw,4rem)] py-20 pt-32 max-lg:grid-cols-1 max-sm:w-[min(100%-36px,1180px)]">
    <div>
      <div class="mb-[30px] flex items-center gap-3">
        <span class="size-2 rounded-full bg-[var(--accent)] shadow-[0_0_16px_2px_var(--accent)]"></span>
        <span class="font-mono text-[0.69rem] uppercase tracking-[0.18em] text-[var(--ink-3)]">Product Engineer / Former Startup CTO</span>
      </div>
      <h1 class="m-0 max-w-[9ch] text-[clamp(3.4rem,10vw,8rem)] font-semibold leading-[0.9] tracking-[-0.045em]">Luke Rucker<span class="block font-normal text-[var(--ink-3)]">builds things.</span></h1>
      <p class="mt-8 max-w-[40ch] text-[clamp(1.06rem,2vw,1.31rem)] leading-[1.6] text-[var(--ink-2)] [text-wrap:pretty]">
        I ship <strong class="font-medium text-[var(--ink)]">AI products end-to-end</strong> - from the systems underneath to the pixels on top.
        Former founding CTO. Currently building side projects and figuring out what is next.
      </p>
    </div>
    <div class="portrait-card relative min-h-[540px] overflow-hidden rounded border border-[var(--rule)] bg-[linear-gradient(180deg,transparent_40%,rgb(8_8_10_/_74%)),radial-gradient(circle_at_66%_28%,rgb(241_87_42_/_34%),transparent_11rem),linear-gradient(140deg,#17171c,#0a0a0c_52%,#24120d)] shadow-[0_50px_100px_-40px_rgb(0_0_0_/_90%)] max-lg:min-h-[380px]" aria-label="Abstract portrait placeholder">
      <div class="absolute -bottom-[0.22em] -right-[0.1em] text-[clamp(8rem,18vw,15rem)] font-bold leading-[0.8] tracking-[-0.09em] text-[rgb(240_238_233_/_9%)]">LR</div>
      <div class="absolute bottom-3.5 left-4"><span class="font-mono text-[0.69rem] uppercase tracking-[0.18em] text-white/85">Fig.01 / Texas, USA</span></div>
    </div>
  </div>
  <div class="mx-auto w-[min(100%-44px,1180px)] max-sm:w-[min(100%-36px,1180px)]"><div class="absolute bottom-[30px] z-[2] flex items-center gap-3 font-mono text-[0.69rem] uppercase tracking-[0.14em] text-[var(--ink-3)] max-lg:hidden"><span class="scroll-line"></span>Scroll</div></div>
</section>
