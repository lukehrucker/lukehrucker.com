---

<section class="relative flex min-h-svh items-center overflow-hidden">
  <div class="pointer-events-none absolute -left-[8%] -top-[34%] z-0 size-[68rem] rounded-full bg-[radial-gradient(circle,var(--accent-soft),transparent_62%)] blur-[8px]"></div>
  <div class="pointer-events-none absolute -bottom-[28%] -right-[10%] z-0 size-[44rem] rounded-full bg-[radial-gradient(circle,rgb(241_87_42_/_10%),transparent_64%)]"></div>
  <div class="site-container relative z-[1] grid grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] items-center gap-[clamp(2rem,6vw,4rem)] py-20 pt-32 max-lg:grid-cols-1">
    <div>
      <div class="mb-[30px] flex items-center gap-3">
        <span class="size-2 rounded-full bg-[var(--accent)] shadow-[0_0_16px_2px_var(--accent)]"></span>
        <span class="font-mono text-[0.69rem] uppercase tracking-[0.18em] text-[var(--ink-3)]">Product Engineer / Former Startup CTO</span>
      </div>
      <h1 class="m-0 max-w-[9ch] text-[clamp(3.4rem,10vw,8rem)] font-semibold leading-[0.9] tracking-[-0.045em]">Luke Rucker<span class="block font-normal text-[var(--ink-3)]">builds things.</span></h1>
      <p class="mt-8 max-w-[40ch] text-[clamp(1.06rem,2vw,1.31rem)] leading-[1.6] text-[var(--ink-2)] [text-wrap:pretty]">
        I ship <strong class="font-medium text-[var(--ink)]">AI products end-to-end</strong> - from the systems underneath to the pixels on top.
        Former founding CTO. Currently building side projects and figuring out what is next.
      </p>
    </div>
    <div class="relative min-h-[540px] overflow-hidden rounded border border-[var(--rule)] bg-[var(--bg-2)] shadow-[0_50px_100px_-40px_rgb(0_0_0_/_90%)] max-lg:min-h-[380px]">
      <img class="absolute inset-0 size-full object-cover" src="/P1002349.jpg" alt="Sunset clouds over a mountain town" />
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgb(8_8_10_/_8%),rgb(8_8_10_/_16%)_42%,rgb(8_8_10_/_78%))]"></div>
      <div class="absolute bottom-3.5 left-4"><span class="font-mono text-[0.69rem] uppercase tracking-[0.18em] text-white/85">Fig.01 / Golden, Colorado</span></div>
    </div>
  </div>
  <div class="absolute inset-x-0 bottom-[30px] z-[2] max-lg:hidden">
    <div class="site-container">
      <div class="flex items-center gap-3 font-mono text-[0.69rem] uppercase tracking-[0.14em] text-[var(--ink-3)]"><span class="scroll-line"></span>Scroll</div>
    </div>
  </div>
</section>
