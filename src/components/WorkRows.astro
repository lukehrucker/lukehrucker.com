---
interface Row {
  href?: string;
  eyebrow: string;
  title: string;
  tag: string;
  description: string;
  action: string;
}

interface Props {
  rows: Row[];
}

const { rows } = Astro.props;
---

<div class="border-t border-[var(--rule)]">
  {
    rows.map((row) => {
      const Tag = row.href ? "a" : "div";

      return (
        <Tag class="group relative grid grid-cols-[130px_minmax(0,1fr)_auto] items-baseline gap-7 border-b border-[var(--rule)] py-[34px] transition-[padding-left] duration-200 before:absolute before:bottom-0 before:left-0 before:top-0 before:w-0.5 before:origin-top before:scale-y-0 before:bg-[var(--accent)] before:transition-transform before:duration-200 hover:pl-[22px] hover:before:scale-y-100 max-md:grid-cols-1 max-md:gap-2" href={row.href} target={row.href ? "_blank" : undefined} rel={row.href ? "noopener" : undefined}>
          <span class="font-mono text-[0.78rem] text-[var(--ink-3)]">{row.eyebrow}</span>
          <div>
            <h3 class="m-0 flex flex-wrap items-center gap-3 text-[clamp(1.38rem,2.6vw,1.88rem)] font-semibold tracking-[-0.02em]">{row.title} <span class="rounded-full border border-[var(--rule-2)] px-2.5 py-1 font-mono text-[0.66rem] font-normal uppercase tracking-[0.08em] text-[var(--ink-2)]">{row.tag}</span></h3>
            <p class="mt-3 max-w-[60ch] text-[0.97rem] leading-[1.6] text-[var(--ink-2)]">{row.description}</p>
          </div>
          <span class="whitespace-nowrap font-mono text-[0.78rem] text-[var(--ink-3)] transition-colors duration-200 group-hover:text-[var(--accent)] max-md:hidden">{row.action}</span>
        </Tag>
      );
    })
  }
</div>
